# ─────────────────────────────────────────────
# KAMZI ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your keys
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# OpenAI API Key for AI features
# Get from: https://platform.openai.com/account/api-keys
# Required for: smart replies, chat summarization, mood detection, 
#               auto-translate, slash commands, vibe status generation
VITE_OPENAI_KEY=sk-your-openai-key-here

# Firebase Cloud Messaging VAPID Key for push notifications
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
# Required for: browser push notifications, background message handling
VITE_FIREBASE_VAPID_KEY=your-vapid-key-here

# Application Environment
# Options: development | staging | production
VITE_APP_ENV=development

# Optional: Sentry DSN for error tracking (production)
# VITE_SENTRY_DSN=https://your-sentry-dsn-here

# Optional: Analytics API key (production)
# VITE_ANALYTICS_KEY=your-analytics-key-here
